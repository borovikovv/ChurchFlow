# Browser-visible canonical URLs. NEXT_PUBLIC_* values are embedded during `next build`.
NEXT_PUBLIC_WEB_URL=https://churchflow.test
NEXT_PUBLIC_API_URL=https://churchflow.test/v1
# Server-only URL used by Next.js server components, middleware, and rewrites.
API_INTERNAL_URL=http://localhost:4000/v1
# Public (not secret) RSA key used by middleware to verify access JWT signatures.
JWT_ACCESS_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\\n...\\n-----END PUBLIC KEY-----\\n"
