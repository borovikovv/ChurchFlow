NODE_ENV=development
PORT=4000
# API runtime database connection. This is separate from packages/db/.env used by Prisma CLI.
DATABASE_URL=postgresql://churchflow:churchflow@localhost:5432/churchflow?schema=public
WEB_APP_URL=https://churchflow.test
COOKIE_DOMAIN=
PLATFORM_ADMIN_EMAIL=admin@example.com
TELEGRAM_CLIENT_ID=
TELEGRAM_CLIENT_SECRET=
TELEGRAM_REDIRECT_URI=
EMAIL_PROVIDER=console
EMAIL_FROM=
RESEND_API_KEY=
JWT_ACCESS_PUBLIC_KEY=replace-with-pem-public-key
JWT_ACCESS_PRIVATE_KEY=replace-with-pem-private-key
JWT_REFRESH_PUBLIC_KEY=replace-with-pem-public-key
JWT_REFRESH_PRIVATE_KEY=replace-with-pem-private-key
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=churchflow-dev
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me
