{
  "name": "@churchflow/db",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "prisma generate && tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev && prisma generate",
    "db:studio": "prisma studio",
    "bootstrap:admin": "prisma generate && node scripts/bootstrap-admin.mjs"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prisma": "^7.8.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  }
}
